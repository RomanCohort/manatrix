{
    // Password Guesser - VS Code Tasks
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Interactive Shell",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "interactive"],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run Training",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "train", "--data", "${input:dataFile}", "--epochs", "100"],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Generate Passwords",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "generate", "--checkpoint", "${input:checkpoint}", "--target", "${input:target}"],
            "problemMatcher": []
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pytest", "tests/", "-v"],
            "problemMatcher": ["$pytest"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Run CLI Tests",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pytest", "tests/test_cli.py", "-v"],
            "problemMatcher": ["$pytest"]
        },
        {
            "label": "Run Web Server",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "web", "--port", "8000"],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true
            }
        },
        {
            "label": "Scan Target",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "scan", "--target", "${input:targetIP}"],
            "problemMatcher": []
        },
        {
            "label": "Generate Chart",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "chart", "-o", "chart.png", "--title", "${input:chartTitle}"],
            "problemMatcher": []
        },
        {
            "label": "Show Help",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "help"],
            "problemMatcher": []
        },
        {
            "label": "Check System Status",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "manatrix.cli", "status"],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "dataFile",
            "type": "promptString",
            "description": "Path to training data file"
        },
        {
            "id": "checkpoint",
            "type": "promptString",
            "description": "Checkpoint file path",
            "default": "checkpoints/best_model.pt"
        },
        {
            "id": "target",
            "type": "promptString",
            "description": "Target information"
        },
        {
            "id": "targetIP",
            "type": "promptString",
            "description": "Target IP or CIDR"
        },
        {
            "id": "chartTitle",
            "type": "promptString",
            "description": "Chart title",
            "default": "Chart"
        }
    ]
}
