{
    // Password Guesser - VS Code Launch Configurations
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Interactive Shell",
            "type": "debugpy",
            "request": "launch",
            "module": "manatrix.cli",
            "args": ["interactive"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Train Model",
            "type": "debugpy",
            "request": "launch",
            "module": "manatrix.cli",
            "args": ["train", "--data", "passwords.txt", "--epochs", "10"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Generate Passwords",
            "type": "debugpy",
            "request": "launch",
            "module": "manatrix.cli",
            "args": ["generate", "--checkpoint", "checkpoints/best_model.pt", "--target", "target"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Web Server",
            "type": "debugpy",
            "request": "launch",
            "module": "manatrix.cli",
            "args": ["web", "--port", "8000"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Scan Target",
            "type": "debugpy",
            "request": "launch",
            "module": "manatrix.cli",
            "args": ["scan", "--target", "192.168.1.1"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/", "-v"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
